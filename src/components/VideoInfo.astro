---
const {
  fotoJose = "/img/jose.jpg",
  title_blue = "De la idea a la nube,",
  title_black = "construimos el futuro de tu negocio.",
  description = "Soluciones cloud a medida, arquitectura de microservicios y optimización de procesos digitales para escalar tu empresa.",
  btn_text = "Agendar consultoría cloud",
} = Astro.props;

const servicios = [
  { nombre: "Arquitectura Cloud / Azure", precio: "$100" },
  { nombre: "Desarrollo Microservicios", precio: "$90" },
  { nombre: "Consultoría Estratégica", precio: "$80" },
  { nombre: "Diseño de APIs / OpenAPI", precio: "$90k" },
];
---

<style is:global>
  /* Importamos Inter para legibilidad y JetBrains para el toque tech */
  @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=JetBrains+Mono:wght@500&display=swap");

  .font-brand {
    font-family: "Inter", sans-serif;
  }
  .font-mono {
    font-family: "JetBrains Mono", monospace;
  }
</style>

<section class="w-full max-w-5xl mx-auto my-12 px-4 font-brand">
  <div
    class="flex flex-col md:flex-row bg-white rounded-[2.5rem] overflow-hidden shadow-2xl border border-gray-100 min-h-[600px] relative"
  >
    <div class="w-full md:w-1/2 relative bg-gray-900 min-h-[350px]">
      <img
        src={fotoJose}
        alt="José Molina"
        class="absolute inset-0 w-full h-full object-cover opacity-90"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-[#0a0044] via-transparent to-transparent opacity-60"
      >
      </div>
      <div class="absolute bottom-10 left-10">
        <p
          class="text-blue-400 font-mono text-xs uppercase tracking-widest mb-1"
        >
          Tech Lead
        </p>
        <p class="text-white font-brand text-2xl font-bold tracking-tight">
          JRINHOUSE
        </p>
      </div>
    </div>

    <div
      class="w-full md:w-1/2 p-10 md:p-16 flex flex-col justify-center bg-white relative"
    >
      <div id="vista-inicio" class="block space-y-8">
        <h2
          class="font-brand text-4xl md:text-5xl font-extrabold leading-[1.1] text-gray-950 tracking-tight"
        >
          <span class="text-blue-600 block">{title_blue}</span>
          {title_black}
        </h2>

        <p class="text-gray-600 text-lg leading-relaxed max-w-sm">
          {description}
        </p>

        <button
          id="btn-abrir-precios"
          class="w-full md:w-auto px-10 py-5 bg-blue-600 hover:bg-gray-900 text-white font-bold text-sm rounded-2xl transition-all duration-300 transform hover:-translate-y-1 shadow-xl shadow-blue-100"
        >
          {btn_text}
        </button>
      </div>

      <div id="vista-precios" class="hidden flex-col w-full animate-fade-in">
        <div
          class="flex items-center justify-between mb-10 border-b border-gray-100 pb-6"
        >
          <h3 class="font-brand text-3xl font-bold text-gray-900">Tarifas</h3>
          <button
            id="btn-cerrar-precios"
            class="font-mono text-xs font-bold text-gray-400 hover:text-red-500 transition-colors border border-gray-200 px-3 py-1 rounded-lg"
          >
            ESC
          </button>
        </div>

        <div class="space-y-4 mb-10">
          {
            servicios.map((s) => (
              <div class="flex justify-between items-center p-5 bg-gray-50 rounded-2xl hover:bg-blue-50/50 transition-colors border border-gray-100">
                <span class="font-brand font-semibold text-gray-800 text-sm">
                  {s.nombre}
                </span>
                <div class="text-right">
                  <span class="font-mono font-bold text-blue-700 text-lg">
                    {s.precio}
                  </span>
                  <span class="text-[10px] text-gray-400 block font-mono">
                    POR HORA
                  </span>
                </div>
              </div>
            ))
          }
        </div>

        <a
          href="https://wa.me/573003146150?text=Hola%20Jose,%20quiero%20agendar%20una%20consultoría"
          target="_blank"
          class="w-full bg-[#25D366] hover:bg-black text-white font-bold py-5 rounded-2xl transition-all shadow-xl flex items-center justify-center gap-3 text-sm"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            fill="currentColor"
            viewBox="0 0 16 16"
          >
            <path
              d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.601 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"
            ></path>
          </svg>
          Chatear por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out forwards;
  }
  #vista-precios.hidden {
    display: none;
  }
</style>

<script>
  const initLogic = () => {
    const btnAbrir = document.getElementById("btn-abrir-precios");
    const btnCerrar = document.getElementById("btn-cerrar-precios");
    const vistaInicio = document.getElementById("vista-inicio");
    const vistaPrecios = document.getElementById("vista-precios");

    if (btnAbrir && btnCerrar && vistaInicio && vistaPrecios) {
      btnAbrir.addEventListener("click", () => {
        vistaInicio.style.display = "none";
        vistaPrecios.classList.remove("hidden");
        vistaPrecios.classList.add("flex");
      });

      btnCerrar.addEventListener("click", () => {
        vistaPrecios.classList.add("hidden");
        vistaPrecios.classList.remove("flex");
        vistaInicio.style.display = "block";
      });
    }
  };

  initLogic();
  document.addEventListener("astro:page-load", initLogic);
  document.addEventListener("astro:after-swap", initLogic);
</script>
