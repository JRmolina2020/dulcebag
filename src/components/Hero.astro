<section id="productos" class="py-16 bg-stone-100 px-4 md:px-6">
  <div class="max-w-7xl mx-auto">

    <h2 class="text-2xl md:text-4xl font-light tracking-widest text-center uppercase mb-12 text-slate-800">
      Nueva Colección
    </h2>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12">

      {productos.map((producto) => (

        <div class="product-card group flex flex-col" data-id={producto.id}>

          <div 
            class="open-modal-trigger relative aspect-square bg-[#f7f7f7] overflow-hidden rounded-md cursor-pointer shadow-sm hover:shadow-md transition-shadow"
            data-nombre={producto.nombre}
            data-precio={producto.precio}
            data-imagen={producto.imagenes[0]}
            data-tag={producto.tag || ''}
            data-descripcion={producto.descripcion || ''}
            data-colores={JSON.stringify(producto.colores || [])}
          >

            <div class="loader absolute inset-0 flex items-center justify-center bg-white z-30 transition-opacity duration-300">
              <div class="w-8 h-8 border-4 border-[#b29a73] border-t-transparent rounded-full animate-spin"></div>
            </div>

            {producto.tag && (
              <span class="absolute top-3 left-3 z-20 bg-[#b29a73] text-white text-[10px] font-bold px-2 py-1 uppercase tracking-wider rounded">
                {producto.tag}
              </span>
            )}

            <div class="absolute inset-0 carousel-container">
              {producto.imagenes.map((img, idx) => (
                <img
                  src={img}
                  alt={`${producto.nombre} ${idx + 1}`}
                  loading="lazy"
                  class={`product-image absolute inset-0 w-full h-full object-contain p-2 transition-opacity duration-700 ease-in-out ${
                    idx === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'
                  }`}
                  onload="this.closest('.product-card').querySelector('.loader')?.classList.add('opacity-0')"
                />
              ))}
            </div>

            <div class="absolute inset-0 bg-black/[0.02] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

          </div>

          <div class="text-center mt-4 flex-grow">
            <h3 class="text-sm md:text-base font-semibold text-neutral-800">
              {producto.nombre}
            </h3>
            <p class="text-xs md:text-sm text-neutral-600 font-bold mt-1">
              {producto.precio}
            </p>
          </div>

          <div class="mt-4">
            <a
              href={`https://wa.me/573003146150?text=${encodeURIComponent(`Hola, me interesa comprar el bolso: ${producto.nombre}`)}`}
              target="_blank"
              class="block w-full text-center bg-[#b29a73] hover:bg-[#9d8765] text-white py-3 rounded-md text-sm font-semibold uppercase tracking-wider transition-all duration-300"
            >
              Comprar
            </a>
          </div>

        </div>

      ))}

    </div>

  </div>
</section>

<div
  id="productModal"
  class="fixed inset-0 hidden z-[9999] bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 transition-opacity duration-300 opacity-0"
>
  <div class="bg-white rounded-2xl max-w-4xl w-full max-h-[90vh] md:max-h-[85vh] overflow-y-auto md:overflow-hidden grid grid-cols-1 md:grid-cols-2 relative shadow-2xl animate-modal-in">
    
    <button
      id="closeProductModal"
      class="absolute top-4 right-4 text-neutral-400 hover:text-neutral-800 text-3xl transition z-50 p-2"
    >
      ×
    </button>

    <div class="relative bg-[#f7f7f7] flex items-center justify-center p-6 min-h-[300px] md:min-h-full">
      <span id="modalTag" class="absolute top-4 left-4 z-20 bg-[#b29a73] text-white text-[10px] font-bold px-2 py-1 uppercase tracking-wider rounded hidden">
        NUEVO
      </span>
      <img
        id="modalProductImg"
        src=""
        alt="Producto"
        class="max-w-full max-h-[400px] md:max-h-[500px] object-contain rounded-lg"
      />
    </div>

    <div class="p-6 md:p-10 flex flex-col justify-center h-full">
      
      <h2 id="modalTitle" class="text-2xl md:text-3xl font-light text-neutral-800 tracking-wide mb-2">
        Nombre del Producto
      </h2>
      
      <p id="modalPrice" class="text-xl font-bold text-neutral-900 mb-6">
        $0 COP
      </p>

      <div class="text-sm text-neutral-600 space-y-2 mb-6 border-t pt-4 border-neutral-100">
        <p id="modalDescription">Cargando descripción...</p>
        <p class="text-xs text-neutral-400 font-medium">Medidas: <span id="modalMeasures">-</span></p>
      </div>

      <div class="mb-4">
        <span class="text-xs font-bold uppercase text-neutral-500 tracking-wider block mb-2">Color</span>
        <div id="modalColorContainer" class="flex gap-2">
          </div>
      </div>

      <div class="mb-8">
        <label for="modalSizeSelect" class="text-xs font-bold uppercase text-neutral-500 tracking-wider block mb-2">Talla / Tamaño</label>
        <div class="relative">
