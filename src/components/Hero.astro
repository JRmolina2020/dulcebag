    tag: "MÁS VENDIDO",
    nombre: "The tote bag negro",
    precio: "$140.000 COP",
    imagenes: ["/img/pp1.png", "/img/pp1.png"]
  },
  {
    id: 2,
    tag: "NUEVO",
    nombre: "The tote bag rosa",
    precio: "$140.000 COP",
    imagenes: ["/img/pp2.png", "/img/pp2.png"]
  },
  {
    id: 3,
    tag: "NUEVO",
    nombre: "The tote bag beige",
    precio: "$140.000 COP",
    imagenes: ["/img/pp3.png", "/img/pp3.png"]
  },
  {
    id: 4,
    tag: "NUEVO",
    nombre: "The tote bag miel",
    precio: "$140.000 COP",
    imagenes: ["/img/pp4.png", "/img/pp4.png"]
  },
    {
    id: 5,
    tag: "PERSONALIZADO",
    nombre: "The mini bag rojo",
    precio: "$70.000 COP",
    imagenes: ["/img/pp5.png", "/img/pp5.png"]
  },
    {
    id: 6,
