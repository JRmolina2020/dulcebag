---

<section id="productos" class="py-16 bg-white px-4 md:px-6">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-2xl md:text-4xl font-light tracking-widest text-center uppercase mb-12 text-slate-800">
      Nueva Colección
    </h2>

    {/* Grid de Productos */}
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12">
      {productos.map((producto) => (
        <div class="product-card group flex flex-col justify-between" data-id={producto.id}>
          
          {/* CAMBIO 1: Cambiado a aspect-square (1:1) para que el contenedor use todo el ancho */}
          <div class="relative aspect-square bg-[#f7f7f7] overflow-hidden rounded-sm cursor-pointer mb-4 flex items-center justify-center transition-transform duration-500 group-hover:scale-[1.03] group-hover:shadow-md">
            
            {/* Tag / Etiqueta del producto (NUEVO / RESTOCK) */}
            {producto.tag && (
              <span class="absolute top-3 left-3 z-20 bg-[#b29a73] text-white text-[10px] font-bold px-2 py-0.5 uppercase tracking-wider rounded-xs shadow-xs">
                {producto.tag}
              </span>
            )}

            {/* Render de Imágenes para el carrusel en Hover */}
            <div class="absolute inset-0 carousel-container">
              {producto.imagenes.map((img, idx) => (
                <img 
                  src={img} 
                  alt={`${producto.nombre} - Vista ${idx + 1}`}
             
                  class={`absolute inset-0 w-full h-full object-contain p-1 mix-blend-multiply transition-opacity duration-700 ease-in-out ${idx === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
                  data-index={idx}
                />
              ))}
            </div>

            {/* Overlay sutil oscuro al hacer hover */}
            <div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10 pointer-events-none"></div>

            {/* Botón Compra Rápida */}
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-20 opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300 w-[85%]">
              <a 
                href={`https://wa.me/573003146150?text=${encodeURIComponent(`Hola, me interesa comprar el bolso: ${producto.nombre}`)}`}
                target="_blank"
                class="flex items-center justify-center gap-2 w-full bg-white text-black font-medium text-xs md:text-sm py-3 px-4 rounded-full shadow-lg hover:bg-neutral-100 transition-colors uppercase tracking-wider"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="w-4 h-4">
                  <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l1.313 7h8.17l1.313-7z"/>
                </svg>
                Compra Rápida
              </a>
            </div>
          </div>

          {/* Información del Producto */}
          <div class="text-center px-1">
            <h3 class="text-sm md:text-base font-semibold text-neutral-800 tracking-tight mb-1">
              {producto.nombre}
            </h3>
            <p class="text-xs md:text-sm text-neutral-600 font-bold">
              {producto.precio}
            </p>
          </div>

        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initProductCarousels() {
    const cards = document.querySelectorAll('.product-card');

    cards.forEach(card => {
      const images = card.querySelectorAll('.carousel-container img') as NodeListOf<HTMLImageElement>;
      if (images.length <= 1) return;

      let intervalId: number | null = null;
      let currentIndex = 0;

      card.addEventListener('mouseenter', () => {
        intervalId = window.setInterval(() => {
          images[currentIndex].classList.replace('opacity-100', 'opacity-0');
          images[currentIndex].classList.replace('z-10', 'z-0');

          currentIndex = (currentIndex + 1) % images.length;

          images[currentIndex].classList.replace('opacity-0', 'opacity-100');
          images[currentIndex].classList.replace('z-0', 'z-10');
        }, 1500); 
      });

      card.addEventListener('mouseleave', () => {
        if (intervalId) {
          clearInterval(intervalId);
          intervalId = null;
        }
        
        images.forEach((img, idx) => {
          if (idx === 0) {
            img.classList.replace('opacity-0', 'opacity-100');
            img.classList.replace('z-0', 'z-10');
          } else {
            img.classList.replace('opacity-100', 'opacity-0');
            img.classList.replace('z-10', 'z-0');
          }
        });
        currentIndex = 0;
      });
    });
  }

  initProductCarousels();
  document.addEventListener('astro:page-load', initProductCarousels);
</script>