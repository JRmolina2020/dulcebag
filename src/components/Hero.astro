            id="modalSizeSelect" 
            class="block w-full bg-white border border-neutral-200 text-neutral-700 py-3 px-4 pr-8 rounded-lg leading-tight focus:outline-none focus:border-[#b29a73] text-sm appearance-none"
          >
            <option>Tamaño Único (Estándar)</option>
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-neutral-500">
            <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
          </div>
        </div>
      </div>

      <div class="space-y-3">
        <a
          id="modalBuyBtn"
          href="#"
          target="_blank"
          class="block w-full text-center bg-[#b29a73] hover:bg-[#9d8765] text-white py-3.5 rounded-lg text-sm font-semibold uppercase tracking-wider transition-all duration-300 shadow-sm"
        >
          Comprar Ahora
        </a>
        
        <a
          id="modalWpSupport"
          href="#"
          target="_blank"
          class="flex items-center justify-center gap-2 w-full text-center text-xs font-medium text-neutral-600 hover:text-neutral-900 transition-colors py-2"
        >
          <svg class="w-4 h-4 fill-current text-green-600" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.713-1.457L0 24zm6.59-4.846c1.6.95 3.398 1.451 5.34 1.452 5.4 0 9.794-4.392 9.797-9.793.002-2.618-1.017-5.08-2.871-6.934C17.009 1.99 14.542.972 12.01.971c-5.4 0-9.794 4.393-9.799 9.795-.001 1.855.485 3.667 1.411 5.263l-.993 3.626 3.714-.974zm11.025-6.924c-.302-.15-1.786-.882-2.056-.98-.27-.099-.467-.148-.663.15-.197.297-.762.979-.933 1.177-.171.198-.343.223-.645.074-.3-.15-1.267-.467-2.413-1.492-.892-.797-1.494-1.781-1.67-2.08-.175-.299-.019-.461.13-.61.135-.133.303-.353.454-.53.151-.176.201-.299.302-.497.101-.199.05-.372-.025-.521-.075-.15-.663-1.597-.91-2.186-.24-.576-.484-.497-.663-.506-.171-.008-.368-.01-.565-.01s-.517.074-.788.372c-.27.297-1.03 1.007-1.03 2.456s1.004 2.848 1.144 3.048c.14.2 1.976 3.018 4.786 4.231.668.289 1.19.462 1.597.592.672.213 1.284.183 1.767.11.539-.08 1.786-.732 2.039-1.441.252-.709.252-1.316.177-1.441-.075-.124-.27-.199-.572-.349z"/></svg>
          ¿Tienes dudas? Consultar por WhatsApp
        </a>
      </div>

    </div>
  </div>
</div>

<style>
  /* Animación refinada de entrada */
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.96); }
    to { opacity: 1; transform: scale(1); }
  }
  .animate-modal-in {
    animation: modalIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<script>
function initProductCarousels() {
  const cards = document.querySelectorAll('.product-card');
  cards.forEach(card => {
    const images = card.querySelectorAll('.carousel-container img');
    if(images.length <= 1) return;

    let currentIndex = 0;
    let intervalId = null;

    card.addEventListener('mouseenter', () => {
      intervalId = setInterval(() => {
        images[currentIndex].classList.replace('opacity-100','opacity-0');
        images[currentIndex].classList.replace('z-10','z-0');
        currentIndex = (currentIndex + 1) % images.length;
        images[currentIndex].classList.replace('opacity-0','opacity-100');
        images[currentIndex].classList.replace('z-0','z-10');
      }, 1500);
    });

    card.addEventListener('mouseleave', () => {
      clearInterval(intervalId);
      images.forEach((img, index) => {
        if(index === 0){
          img.classList.replace('opacity-0','opacity-100');
          img.classList.replace('z-0','z-10');
        } else {
          img.classList.replace('opacity-100','opacity-0');
          img.classList.replace('z-10','z-0');
        }
      });
      currentIndex = 0;
    });
  });
}

function initProductModal() {
  const modal = document.getElementById('productModal');
  const closeBtn = document.getElementById('closeProductModal');
  
  // Elementos internos del modal
  const modalImg = document.getElementById('modalProductImg');
  const modalTitle = document.getElementById('modalTitle');
  const modalPrice = document.getElementById('modalPrice');
  const modalTag = document.getElementById('modalTag');
  const modalDescription = document.getElementById('modalDescription');
  const modalMeasures = document.getElementById('modalMeasures');
  const modalColorContainer = document.getElementById('modalColorContainer');
  const modalBuyBtn = document.getElementById('modalBuyBtn');
  const modalWpSupport = document.getElementById('modalWpSupport');

  if (!modal) return;

  // Escuchar clicks en el contenedor/trigger de la imagen de cada tarjeta
  document.querySelectorAll('.open-modal-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      // 1. Extraer los datos del dataset del HTML de Astro
      const nombre = trigger.getAttribute('data-nombre');
      const precio = trigger.getAttribute('data-precio');
      const imagen = trigger.getAttribute('data-imagen');
      const tag = trigger.getAttribute('data-tag');
      const descripcion = trigger.getAttribute('data-descripcion');
      const medidas = trigger.getAttribute('data-medidas');
      const colores = JSON.parse(trigger.getAttribute('data-colores') || '[]');

      // 2. Renderizar la información en la ventana modal
      modalImg.src = imagen;
      modalImg.alt = nombre;
      modalTitle.textContent = nombre;
      modalPrice.textContent = precio;
      modalDescription.textContent = descripcion;
      modalMeasures.textContent = medidas;

      // Tag Condicional
      if (tag) {
        modalTag.textContent = tag;
        modalTag.classList.remove('hidden');
      } else {
        modalTag.classList.add('hidden');
      }

      // Renderizar círculos de colores
      modalColorContainer.innerHTML = '';
      colores.forEach((color, idx) => {
        const span = document.createElement('span');
        span.className = `w-6 h-6 rounded-full border border-neutral-300 cursor-pointer inline-block transition-transform hover:scale-110 ${idx === 0 ? 'ring-2 ring-[#b29a73] ring-offset-2' : ''}`;
        span.style.backgroundColor = color;
        modalColorContainer.appendChild(span);
      });

      // Actualizar URLs de conversión a WhatsApp
      const wpBaseText = `Hola, me interesa comprar el bolso: ${nombre}`;
      const wpSupportText = `Hola, tengo una consulta sobre el producto: ${nombre}`;
      modalBuyBtn.href = `https://wa.me/573003146150?text=${encodeURIComponent(wpBaseText)}`;
      modalWpSupport.href = `https://wa.me/573003146150?text=${encodeURIComponent(wpSupportText)}`;

      // 3. Ejecutar animaciones de apertura
      modal.classList.remove('hidden');
      setTimeout(() => { modal.classList.add('opacity-100') }, 10);
      document.body.style.overflow = 'hidden';
    });
  });

  // Función para cerrar modal
  const closeModal = () => {
    modal.classList.remove('opacity-100');
    setTimeout(() => { modal.classList.add('hidden') }, 300);
    document.body.style.overflow = '';
  }

  closeBtn?.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if(e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if(e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });
}

// Inicialización respetando el ciclo de vida de Astro
document.addEventListener('DOMContentLoaded', () => {
  initProductCarousels();
  initProductModal();
});

document.addEventListener('astro:page-load', () => {
  initProductCarousels();
  initProductModal();
});
</script>