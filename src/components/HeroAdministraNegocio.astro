---
const {
  title = "Administra tu negocio",
  subtitle = "CuarentaF es la plataforma que te ayuda a controlar tus ventas, gastos, inventario y reportes. Todo desde un solo lugar, sin complicaciones.",
  cta = "Hablemos de software",
  image = "/img/yo.png",
} = Astro.props;
---

<section
  class="relative w-full min-h-screen px-6 flex items-center justify-center text-center bg-cover"
  style={`background-image: url(${image}); background-position: center 80%;`}
>
  <!-- Overlay oscuro para legibilidad -->
  <div class="absolute inset-0 bg-black/60"></div>

  <!-- Contenido -->
  <div class="relative z-10 max-w-2xl">
    <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-4">
      {title}
    </h2>
    <p class="text-white/80 text-base md:text-lg mb-8">
      {subtitle}
    </p>

    <a
      href="https://wa.me/573003146150?text=Hola,%20quiero%20hablar%20de%20software"
      class="btn-premium text-white px-8 py-3 rounded-full font-semibold shadow-lg transition inline-block"
      target="_blank"
    >
      {cta}
    </a>
  </div>

  <!-- Estilos -->
  <style>
    .btn-premium {
      background: linear-gradient(135deg, #4f46e5, #7c3aed, #ef4444);
      transition: all 0.3s ease;
    }

    .btn-premium:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(79,70,229,0.4);
      filter: brightness(1.05);
    }
  </style>
</section>
