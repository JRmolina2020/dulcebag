---
const {
  title = "Transformo ideas en software",
  subtitle = "Soy José R. Molina, ingeniero de software de Valledupar y fundador de JRINHOUSE y CuarentaF. Más de 5 años desarrollando soluciones cloud y aplicaciones escalables.",
  cta = "",
  image = "/img/yo.png",
} = Astro.props;
---

<section
  class="relative w-full min-h-screen px-6 flex items-center justify-center text-center bg-cover bg-no-repeat"
  style={`background-image: url(${image}); background-position: center 80%;`}
>
  {/* Capa oscura de superposición para mejorar el contraste del texto */}
  <div class="absolute inset-0 bg-black/70"></div>

  <div class="relative z-10 max-w-4xl mx-auto flex flex-col items-center justify-center">
    <h2 class="text-3xl md:text-6xl font-extrabold text-white mb-6 uppercase tracking-tight leading-tight">
      {title}
    </h2>

    <p class="text-white/80 text-base md:text-xl mb-10 max-w-2xl">
      {subtitle}
    </p>

    <a
      href="https://wa.me/573003146150?text=Hola,%20quiero%20comprar%20%20una referencia"
      class="btn-white-premium px-10 py-4 rounded-full font-bold shadow-xl transition inline-block uppercase tracking-widest text-sm md:text-base"
      target="_blank"
    >
      {cta}
    </a>
  </div>

  <style>
    /* Estilo Premium del Botón Blanco */
    .btn-white-premium {
      background-color: #ffffff;
      color: #000000;
      border: 1px solid rgba(255, 255, 255, 0.2);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .btn-white-premium:hover {
      background-color: #f3f4f6;
      transform: translateY(-4px) scale(1.02);
      box-shadow:
        0 20px 25px -5px rgba(0, 0, 0, 0.3),
        0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }
  </style>
</section>