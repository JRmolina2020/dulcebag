---
// src/components/SoporteInfo.astro
---

<section class="bg-black text-white py-20 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-center text-2xl md:text-3xl font-bold mb-6">
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 to-blue-500">
        La tecnología no debe ser un problema,
      </span>
      <br class="hidden md:block" />
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 to-blue-500">
        debe ser la solución.
      </span>
    </h2>

    <hr class="border-t border-cyan-400/40 mb-10 w-2/3 mx-auto" />

    <div class="grid md:grid-cols-2 gap-8 items-center">
      <!-- Descripción -->
      <div>
        <p class="text-lg leading-relaxed text-blue-200/80">
          Diseño arquitecturas y sistemas en la nube que simplifican procesos,
          reducen la carga técnica y convierten ideas en soluciones reales.
        </p>
      </div>

      <!-- Métrica con animación -->
      <div class="bg-[#0c0c1d] rounded-xl text-center p-8 border border-cyan-400/30 shadow-lg shadow-cyan-500/20">
        <div
          id="contador"
          class="text-4xl font-bold mb-2 bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 to-blue-500"
        >
          0
        </div>
        <p class="text-sm text-blue-200/70">
          clientes que optimizaron sus procesos mediante soluciones de software.
        </p>
      </div>
    </div>
  </div>

  <!-- Script CountUp -->
  <script type="module" is:inline>
    import { CountUp } from "https://cdn.skypack.dev/countup.js";

    const el = document.getElementById("contador");
    if (el) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const countUp = new CountUp("contador", 38, {
              duration: 2,
              separator: ".",
            });
            countUp.start();
            observer.disconnect();
          }
        });
      });

      observer.observe(el);
    }
  </script>
</section>
